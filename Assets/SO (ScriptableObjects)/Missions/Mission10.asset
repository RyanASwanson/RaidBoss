  _tutorialPages:
  - TutorialPageTitle: Healing
    TutorialPageTitleWidth: 525
    DefaultTextLocation: {x: 0, y: 0}
    DefaultText: 'Some heroes have ways in which they

      can heal themselves
      or other heroes. Utilize

      the healing sustain yourself in harder fights.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 0
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: The Chronomancer
    TutorialPageTitleWidth: 1100
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The Chronomancer is a clutch and

      precise healer. She can
      undo major

      mistakes, while providing some

      utility to help allies
      deal damage.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: fe2bf9c72fd89414ca1dc07e70fefe01, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Time Blast
    TutorialPageTitleWidth: 650
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Chronomancer''s basic ability is Time Blast.

      The Chronomancer
      fires a projectile in a

      clockwork pattern that can heal allies, and

      damage
      the boss.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 561524586736d2e4ca7cedbe3c90cc73, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Rewind
    TutorialPageTitleWidth: 525
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Chronomancer''s active ability

      is Rewind. The Chronomancer
      reverses

      all damage taken by heroes

      in the past few seconds.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 25df8652d4f478243847ad1e38f346be, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Accelerate
    TutorialPageTitleWidth: 650
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Chronomancer''s passive ability is Accelerate.

      The Chronomancer
      speeds up the next use

      of a heroes basic ability, when she affects

      them
      with her abilities.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1

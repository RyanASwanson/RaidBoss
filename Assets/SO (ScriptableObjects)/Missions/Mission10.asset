  _tutorialPages:
  - TutorialPageTitle: Healing
    TutorialPageTitleWidth: 427
    DefaultTextLocation: {x: 0, y: 60}
    DefaultText: 'Some Heroes have ways in which

      they can heal themselves
      or other

      Heroes. Utilize the healing to

      sustain yourself in harder
      fights.'
    TutorialPageObjectLocation: {x: 0, y: -80}
    TutorialPageObject: {fileID: 8802351148540139332, guid: b57606bb3808e4b4787469467daa649e, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 0
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: 'Hero: The Chronomancer'
    TutorialPageTitleWidth: 1381
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The <color=#FBFF00>Chronomancer</color> is a clutch and

      precise
      healer. She can undo major

      mistakes while providing buffs

      to
      help allies deal damage.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: fe2bf9c72fd89414ca1dc07e70fefe01, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Time Blast
    TutorialPageTitleWidth: 580
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FBFF00>Chronomancer</color>''s basic ability is <color=#EBDB00>Time
      Blast</color>.

      The <color=#FBFF00>Chronomancer</color> fires a projectile
      in a

      clockwork pattern that can heal allies and

      damage the Boss.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 561524586736d2e4ca7cedbe3c90cc73, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Rewind
    TutorialPageTitleWidth: 418
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FBFF00>Chronomancer</color>''s active ability

      is
      <color=#EBDB00>Rewind</color>. The <color=#FBFF00>Chronomancer</color> reverses

      all
      damage taken by heroes

      in the past few seconds.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 25df8652d4f478243847ad1e38f346be, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Accelerate
    TutorialPageTitleWidth: 582
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FBFF00>Chronomancer</color>''s passive ability

      is
      <color=#EBDB00>Accelerate</color>. The <color=#FBFF00>Chronomancer</color>
      speeds

      up the cooldowns of allies that

      she affects with her abilities.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1

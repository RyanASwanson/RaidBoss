  _tutorialPages:
  - TutorialPageTitle: The Mirage
    TutorialPageTitleWidth: 735
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The Mirage is a deceptive and

      complex damage dealer. It
      utilizes

      a clone to decieve the boss and

      counterattack.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 907986429f001e94f80f4d482d34513b, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Mirage Clone
    TutorialPageTitleWidth: 800
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Mirage has a sand

      clone that is utilized in

      all
      of its abilities.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: cc73c377a2f1f6d489e1fee45cb15de1, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Sandblast
    TutorialPageTitleWidth: 625
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Mirage''s basic ability is

      Sandblast. The Mirage creates

      pillars
      that stab at the midpoint

      between the Mirage and it''s clone.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: c5d2e63deba4afb4299ff5a01de3f206, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Sandstone Clone
    TutorialPageTitleWidth: 1025
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Mirage''s active ability is

      Sandstone Clone. The Mirage

      swaps
      places with its clone with

      a short cooldown.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 9a9468215be2ca6488e0b159d8153429, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Diversion
    TutorialPageTitleWidth: 625
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Mirage''s passive ability is

      Diversion. The Mirage''s
      clone can be

      targeted and attacked by the boss. If it

      gets hit
      by the boss it casts Sandblast.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: cc73c377a2f1f6d489e1fee45cb15de1, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}

  _tutorialPages:
  - TutorialPageTitle: Stagger
    TutorialPageTitleWidth: 525
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'When Heroes attack, they deal stagger as

      well as damage.
      When the Boss takes enough

      stagger they are stunned and take increased

      damage.
      You can see the stagger progress of

      the Boss in yellow at the top of
      the screen.'
    TutorialPageObjectLocation: {x: 0, y: -70}
    TutorialPageObject: {fileID: 1907742723051834283, guid: 0c6ded0d6b92d2b4d9a4b594df0f6f8c, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Safe Zones
    TutorialPageTitleWidth: 700
    DefaultTextLocation: {x: 0, y: 60}
    DefaultText: 'Some Boss attacks have blue safe zones.

      If at least one
      Hero is in the safe zone it will

      prevent the attack entirely.'
    TutorialPageObjectLocation: {x: 0, y: -45}
    TutorialPageObject: {fileID: 8878142049407289308, guid: 57c07eee93d31b4408341ca174634d15, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Enrage
    TutorialPageTitleWidth: 475
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'Taking too long too cause the Boss to

      become enraged, dealing
      increased damage

      and enhancing their abilities. A blue bar

      will
      appear at the top of the screen when

      the Boss is close to getting enraged.'
    TutorialPageObjectLocation: {x: 0, y: -70}
    TutorialPageObject: {fileID: 8595946271849662049, guid: 2892c5f69431f154d96f9b94be1c9a88, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Enraged Attacks
    TutorialPageTitleWidth: 975
    DefaultTextLocation: {x: 0, y: 75}
    DefaultText: 'While enraged some Boss

      abilities gain new effects.'
    TutorialPageObjectLocation: {x: 0, y: -32}
    TutorialPageObject: {fileID: 554136623965309169, guid: b25feb162b11d804e86084c48b9456f6, type: 3}

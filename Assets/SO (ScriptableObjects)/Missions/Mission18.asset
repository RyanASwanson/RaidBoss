  _tutorialPages:
  - TutorialPageTitle: 'Hero: The Mirage'
    TutorialPageTitleWidth: 960
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The <color=#FFEB23>Mirage</color> is a deceptive and

      complex
      damage dealer. It utilizes

      a clone to deceive the Boss and

      counterattack.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 907986429f001e94f80f4d482d34513b, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Mirage Clone
    TutorialPageTitleWidth: 730
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FFEB23>Mirage</color> has a sand

      clone that
      is utilized in

      all of its abilities.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: cc73c377a2f1f6d489e1fee45cb15de1, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Sandblast
    TutorialPageTitleWidth: 541
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FFEB23>Mirage</color>''s basic ability is

      <color=#E9C429>Sandblast</color>.
      The <color=#FFEB23>Mirage</color> creates

      pillars that stab at the midpoint

      between
      the <color=#FFEB23>Mirage</color> and its clone.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: c5d2e63deba4afb4299ff5a01de3f206, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Sandstone Clone
    TutorialPageTitleWidth: 906
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FFEB23>Mirage</color>''s active ability is

      <color=#E9C429>Sandstone
      Clone</color>. The <color=#FFEB23>Mirage</color>

      swaps places with its
      clone on

      a short cooldown.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 9a9468215be2ca6488e0b159d8153429, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Diversion
    TutorialPageTitleWidth: 537
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#FFEB23>Mirage</color>''s passive ability is

      <color=#E9C429>Diversion</color>.
      The <color=#FFEB23>Mirage</color>''s clone can be

      targeted and attacked
      by the Boss. If it

      gets hit by the Boss, it casts <color=#E9C429>Sandblast</color>.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: cc73c377a2f1f6d489e1fee45cb15de1, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}

    _bossStaggerMultiplier: 1
    _bossAttackSpeedMultiplier: 0.8
    _bossDamageResistanceChangeOnStaggerMultiplier: 1
    _bossEnrageTimeMultiplier: 1.5
    _bossEnrageDamageMultiplier: 1
    _bossAbilitiesUsable: 0101000100
    _heroHealthMultiplier: 1
    _heroDamageMultiplier: 1
    _heroStaggerMultiplier: 0
    _heroHealingReceivedMultiplier: 1
    _heroManualCooldownTimeMultiplier: 1

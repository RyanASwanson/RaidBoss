  _tutorialPages:
  - TutorialPageTitle: The Shaman
    TutorialPageTitleWidth: 775
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The Shaman is a well rounded and

      strategic damage dealer.
      He deals damage

      over wide areas while waiting for his

      opportunity
      to line up repeated damage.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 50055fdb0508a044691e25a12d99168b, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Tornado
    TutorialPageTitleWidth: 560
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Shaman''s basic ability is

      Tornado. The Shaman creates
      a

      tornado which deals damage and

      low stagger vertically.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 8bdea33b2b0c3674fa19fde192c3bec8, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Ball Lightning
    TutorialPageTitleWidth: 880
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Shaman''s active ability is Ball Lightning.

      The Shaman
      fires a ball of lightning that bounces

      between all heroes. Line it up
      to hit the boss

      multiple times.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 53c272ff603dd9d48a50f92ca834ec29, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Spirit Totem
    TutorialPageTitleWidth: 740
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Shaman''s passive ability is Spirit Totem.

      The Shaman
      creates a totem at his location after

      using Ball Lightning. The next
      use of Ball Lightning

      will bounce off of the totem as well as all heroes.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 8a84224464139aa4790c50fec3f988e0, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}

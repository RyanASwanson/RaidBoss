  - TutorialPageTitle: Mystery Concoction
    TutorialPageTitleWidth: 1150
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Alchemist''s active ability is

      Mystery Concoction. The
      Alchemist

      throws a potion that randomly provide a

      buff to damage,
      stagger, speed, or healing.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:

  - TutorialPageTitle: The Alchemist
    TutorialPageTitleWidth: 900
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The Alchemist is a volatile and

      supportive healer. She provides
      her

      team with good healing and

      unpredictable buffs.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}

  _missionDisplayHighlights: []
  _tutorialPages:
  - TutorialPageTitle: Volcano
    TutorialPageTitleWidth: 540
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The <color=#F57C34>Magma Lord</color> burns

      hotter than
      ever before. A new

      ability has arisen. <color=#FF420D>Volcano</color>

      is
      a hybrid between a passive

      and active ability.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 3f36a531e11b5f74aa9726acfffe8707, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Stay On Your Toes
    TutorialPageTitleWidth: 1090
    DefaultTextLocation: {x: 0, y: 52}
    DefaultText: 'Heroes that stay still

      for too long will start to

      get
      hotter, but will

      cool off as they move.'
    TutorialPageObjectLocation: {x: 0, y: -55}
    TutorialPageObject: {fileID: 2859117182787882857, guid: 635079945faf2ce42b0bb997c8cf2fd1, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Hot Feet
    TutorialPageTitleWidth: 585
    DefaultTextLocation: {x: 0, y: 0}
    DefaultText: 'When a Hero reaches max

      heat, a target zone will spawn.

      When
      the <color=#F57C34>Magma Lord</color> uses

      <color=#FF420D>Volcano</color>
      it will attack at all

      spawned target zones.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}

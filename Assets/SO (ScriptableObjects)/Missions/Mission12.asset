  - TutorialPageTitle: The Glacial Lord
    TutorialPageTitleWidth: 950
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'A new foe has appeared. The Glacial

      Lord utilized its Frost
      Fiend minions and

      ice attacks to shatter your heroes.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:

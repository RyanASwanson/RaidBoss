  - TutorialPageTitle: Frost Fiends Weakness
    TutorialPageTitleWidth: 1300
    DefaultTextLocation: {x: 0, y: 50}
    DefaultText: 'Attacks performed by the Glacial Lord

      can freeze Frost Fiends,
      entirely preventing

      them from being able to attack. Line up

      the
      Glacial Lords attacks with Frost Fiends.'
    TutorialPageObjectLocation: {x: 0, y: -55}
    TutorialPageObject: {fileID: 4219184930868017209, guid: a9ba70893c03f9244976c55d023b89f6, type: 3}

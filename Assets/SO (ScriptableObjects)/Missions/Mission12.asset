  - TutorialPageTitle: Frost Fiends
    TutorialPageTitleWidth: 800
    DefaultTextLocation: {x: 0, y: 35}
    DefaultText: 'The Glacial Lord has Frost Fiends around

      the arena that
      perform some of the attacks

      for the Glacial Lord.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}

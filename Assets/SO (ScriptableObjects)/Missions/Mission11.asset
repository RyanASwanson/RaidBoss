  _tutorialPages:
  - TutorialPageTitle: Difficulties
    TutorialPageTitleWidth: 750
    DefaultTextLocation: {x: 0, y: 50}
    DefaultText: 'Different missions have different difficulty

      levels. The
      difficulty of a mission can be

      seen next to the boss on the mission
      scroll

      in the mission selection.'
    TutorialPageObjectLocation: {x: 0, y: -55}
    TutorialPageObject: {fileID: 2483143276828620687, guid: f9f3f9b54b99f5a49a86895f3f155aa2, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 0
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Difficulties Levels
    TutorialPageTitleWidth: 1065
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'There are 4 main difficulty levels, which are

      Normal, Heroic,
      Mythic, and Mythic+.'
    TutorialPageObjectLocation: {x: 0, y: -40}
    TutorialPageObject: {fileID: 6938674043408630033, guid: 14763028804c0004597e6979452edb68, type: 3}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 0
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Heroic
    TutorialPageTitleWidth: 450
    DefaultTextLocation: {x: 0, y: 0}
    DefaultText: 'Previous missions were all on Normal. This

      mission is increased
      to Heroic. On higher

      difficulties, the boss deals more damage,

      has
      more health, is harder to stagger,

      and attacks slightly faster.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 0
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}
  - TutorialPageTitle: Max Heroes
    TutorialPageTitleWidth: 750
    DefaultTextLocation: {x: 0, y: 0}
    DefaultText: 'Additionally as the difficulty increases the

      max number
      of heroes also increases. The max

      number of heroes on Normal is 3, on
      Heroic

      it is 4, and on Mythic and Mythic+ it is 5.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: 0}
      TutorialCharacterIconScaleMultiplier: 0
      TutorialPageCharacterIcon: {fileID: 0}
      TutorialPageCharacterBackground: {fileID: 0}

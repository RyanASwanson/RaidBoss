  _tutorialPages:
  - TutorialPageTitle: 'Hero: The Guardian'
    TutorialPageTitleWidth: 1150
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The <color=#81F308>Guardian</color> is a stalwart and

      durable
      tank. He creates

      opportunities for his allies by

      staggering and
      distracting the Boss.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 4184165ee7d65e54ea0f6f63f2a3cc0a, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Shield Slam
    TutorialPageTitleWidth: 800
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#81F308>Guardian</color>''s basic ability is <color=#6FD404>Shield
      Slam</color>.

      The <color=#81F308>Guardian</color> slams his shield into
      the

      ground, inflicting heavy stagger and some

      damage in an area
      around him.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 47716a4ce1a834f45a9d03f89061606e, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Taunt
    TutorialPageTitleWidth: 500
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#81F308>Guardian</color>''s manual ability is <color=#6FD404>Taunt</color>.

      The
      <color=#81F308>Guardian</color> draws the attention of

      the Boss while
      reducing damage taken.

      Targeted Boss attacks will always

      target
      the <color=#81F308>Guardian</color> while active.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 58180ad792aad314c94100472d262f81, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Resilience
    TutorialPageTitleWidth: 700
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The <color=#81F308>Guardian</color>''s passive ability is <color=#6FD404>Resilience</color>.

      The
      <color=#81F308>Guardian</color> takes reduced damage

      for a brief amount
      of time after

      taking damage.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: aedd22e0a7c49254093a1ecf2a8de938, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}

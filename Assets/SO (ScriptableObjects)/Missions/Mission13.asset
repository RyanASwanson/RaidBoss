  _tutorialPages:
  - TutorialPageTitle: The Vampire
    TutorialPageTitleWidth: 825
    DefaultTextLocation: {x: 0, y: 43}
    DefaultText: 'The Vampire is a bloodthirsty

      and unkillable tank. She inflicts

      heavy
      stagger, all while healing

      from any damage dealt.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -60}
      TutorialCharacterIconScaleMultiplier: 1

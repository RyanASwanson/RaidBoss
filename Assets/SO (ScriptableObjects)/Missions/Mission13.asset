      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Blood Lance
    TutorialPageTitleWidth: 775
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Vampire''s basic ability is Blood Lance.

      The Vampire
      fires a projectile that splits

      into 3 projectiles after a short distance
      dealing

      heavy stagger. Line up the distance just right

      to get
      the most use out of it.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: f76c063393ef8e645a7ae785867d7cbc, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Bat Swarm
    TutorialPageTitleWidth: 725
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Vampire''s basic ability is Bat Swarm.

      The Vampire disperses
      into a swarm of bats

      becoming immune to damage and gaining

      increased
      healing.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 3f0341e4515938443b042eb518d670d0, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Lifesteal
    TutorialPageTitleWidth: 640
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Vampire''s basic ability is Lifesteal.

      The Vampire heals
      proportional

      to the damage she deals.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}

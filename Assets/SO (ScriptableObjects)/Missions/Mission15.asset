  - TutorialPageTitle: Multishot
    TutorialPageTitleWidth: 635
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Fae''s basic ability is Multishot.

      The Fae fires arrows
      around her in

      4 diagonal directions.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: ae08c1101f2f79b44acc726e516f5084, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Flurry
    TutorialPageTitleWidth: 510
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Fae''s active ability is Flurry.

      The Fae bounces around
      uncontrollably,

      dealing damage when she collides with

      the boss.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: a157f7d99ad33a64184d1317ec333ced, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Fleet-footed
    TutorialPageTitleWidth: 740
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Fae''s passive ability is Fleet-footed.

      The Fae can
      use Multishot while moving

      and fires it more frequently while doing
      so.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}

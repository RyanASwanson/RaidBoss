  _tutorialPages:
  - TutorialPageTitle: The Astromancer
    TutorialPageTitleWidth: 1000
    DefaultTextLocation: {x: 0, y: 45}
    DefaultText: 'The Astromancer is a slow and

      powerful damage dealer. He
      is

      able to unleash powerful spells,

      but leaves himself open to
      damage.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: de4cd028229d01d41b498bca06f0c960, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: cad11a2bf12278c46a02ba6a7ef54eec, type: 3}
  - TutorialPageTitle: Shooting Star
    TutorialPageTitleWidth: 860
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Astromancer''s basic ability is

      Shooting Star. The Astromancer
      fires a

      projectile at the boss that bounces back.

      If it collides
      with the Astromancer on its

      return it is reflected back at the boss.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 90a97845e8c5d6b4fb158d2e572af5c8, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Celestial Onslaught
    TutorialPageTitleWidth: 1125
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Astromancer''s active ability is

      Celestial Onslaught.
      The Astromancer

      stands still and fires projectiles at the

      boss
      until he moves.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 55efa58f25f54b34f8ea506ecabd4f8d, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
  - TutorialPageTitle: Stars Align
    TutorialPageTitleWidth: 730
    DefaultTextLocation: {x: 0, y: 40}
    DefaultText: 'The Astromancer''s passive ability is

      Stars Align. The Astromancer
      reduces

      the cooldown of Celestial Onslaught

      when reflecting Shooting
      Star.'
    TutorialPageObjectLocation: {x: 0, y: 0}
    TutorialPageObject: {fileID: 0}
    TutorialPageCharacterTutorial:
      TutorialCharacterIconLocation: {x: 0, y: -65}
      TutorialCharacterIconScaleMultiplier: 1
      TutorialPageCharacterIcon: {fileID: 21300000, guid: 842cf0206d9baa44b86423dcff5761c3, type: 3}
      TutorialPageCharacterBackground: {fileID: 21300000, guid: e1908552323c2764f9a06cd60265194a, type: 3}
